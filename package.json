{
  "name": "tacv",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript Agentic Coding Workflow",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run --workspace vitest.workspace.ts",
    "test:cov": "vitest run --workspace vitest.workspace.ts --coverage",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rimraf node_modules",
    "start:worker": "pnpm --filter @tacv/core node dist/worker.js",
    "tacv": "pnpm --filter @tacv/cli node src/main.ts"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5",
    "@vitest/coverage-v8": "^2.0.5"
  }
}